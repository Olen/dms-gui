# eslint-plugin-react@7.x peer-deps cap at eslint@9.7, but the project
# is on eslint@10. Until eslint-plugin-react releases an eslint@10
# compatible version, npm refuses to install at this directory without
# legacy-peer-deps. CI doesn't hit this because it installs from
# backend/ and frontend/ workspaces (not the root); this flag fixes
# the local-dev experience for `npm install` / `npm ci` at root.
legacy-peer-deps=true
