{
  "name": "dms-gui",
  "version": "2.2.0",
  "type": "module",
  "main": "index.js",
  "description": "[![Docker Pulls](https://img.shields.io/docker/pulls/audioscavenger/dms-gui)](https://hub.docker.com/r/audioscavenger/dms-gui)",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint backend/ frontend/src/ common.mjs frontend/frontend.mjs",
    "lint:fix": "eslint --fix backend/ frontend/src/ common.mjs frontend/frontend.mjs",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "prettier": "^3.7.4"
  },
  "comment-overrides": "brace-expansion <1.1.13 has a ReDoS-style hang via zero-step sequences. Pulled in transitively by eslint-plugin-react → minimatch@3 → brace-expansion@1. eslint-plugin-react has not yet released a minimatch@9-compatible version, so pin brace-expansion at the npm level until the upstream upgrade lands.",
  "overrides": {
    "brace-expansion": "^1.1.13"
  },
  "lint-staged": {
    "backend/**/*.{js,mjs}": [
      "prettier --write",
      "eslint --no-error-on-unmatched-pattern"
    ],
    "frontend/src/**/*.{js,jsx}": [
      "prettier --write",
      "eslint --no-error-on-unmatched-pattern"
    ],
    "frontend/frontend.mjs": [
      "prettier --write",
      "eslint --no-error-on-unmatched-pattern"
    ],
    "common.mjs": [
      "prettier --write",
      "eslint --no-error-on-unmatched-pattern"
    ],
    "**/*.{css,json}": [
      "prettier --write"
    ],
    "frontend/public/index.html": [
      "prettier --write"
    ]
  }
}
