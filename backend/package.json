{
  "name": "dms-gui-backend",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file-if-exists=.env --env-file-if-exists=../config/.dms-gui.env index.js",
    "dev": "nodemon --exec 'node --env-file-if-exists=.env --env-file-if-exists=../config/.dms-gui.env' index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"**/*.{js,json}\"",
    "format:check": "prettier --check \"**/*.{js,json}\""
  },
  "keywords": [
    "docker",
    "mailserver",
    "gui",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "description": "Backend API for dms-gui",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "prettier": "3.8.3",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "vitest": "^4.1.5"
  }
}
